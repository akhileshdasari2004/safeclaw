# =============================================================================
# SafeClaw — Environment Variables (copy to .env for local dev)
# =============================================================================

# --- App ---
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/safeclaw
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/safeclaw

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
ENCRYPTION_KEY=change-me-32-byte-base64-or-fernet-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/pricing?checkout=cancelled

# --- Resend ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=SafeClaw <onboarding@resend.dev>

# --- Cloud Providers ---
HETZNER_API_TOKEN=
DIGITALOCEAN_API_TOKEN=

# --- SSH / Provisioning ---
SSH_CONNECT_TIMEOUT=30
SSH_COMMAND_TIMEOUT=300
PROVISION_MAX_RETRIES=3
PROVISION_POLL_INTERVAL=10

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Alerts Worker ---
ALERTS_POLL_INTERVAL_SECONDS=3600
ALERT_COOLDOWN_HOURS=24

# --- OpenClaw (installed on provisioned servers) ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_PORT=18789
