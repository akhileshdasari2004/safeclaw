{
  "name": "safeclaw",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "packages/shared-types",
    "packages/config"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev -w @safeclaw/frontend\" \"make backend-dev\"",
    "build": "npm run build -w @safeclaw/frontend",
    "lint": "npm run lint -w @safeclaw/frontend",
    "test": "npm run test -w @safeclaw/frontend && make backend-test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
